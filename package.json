{
  "name": "astro-image-processor",
  "version": "0.2.0",
  "description": "Astro integartion for image optimization and art direction for static builds",
  "keywords": [
    "astro",
    "astro-component",
    "astro-integration",
    "image",
    "sharp",
    "withastro"
  ],
  "homepage": "https://macropygia.github.io/astro-image-processor/",
  "bugs": "https://github.com/macropygia/astro-image-processor/discussions/new/choose",
  "license": "MIT",
  "author": "macropygia",
  "repository": {
    "type": "git",
    "url": "https://github.com/macropygia/astro-image-processor"
  },
  "files": [
    "tsconfig.json",
    "src",
    "!src/components/index.ts",
    "!src/extras/index.ts",
    "!src/api/index.ts",
    "!**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./config": "./src/config/index.ts",
    "./const": "./src/const.ts",
    "./components/*": "./src/components/*",
    "./extras/*": "./src/extras/*.ts",
    "./api/*": "./src/api/*.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "oxlint --tsconfig ./tsconfig.json --type-aware --type-check",
    "test:watch": "vitest",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "test:bun": "bun test bun",
    "coverage": "vitest run --coverage",
    "dev": "astro dev --config astro.default.ts --root __test__",
    "build": "astro build --config astro.default.ts --root __test__",
    "build:loki": "astro build --config astro.loki.ts --root __test__",
    "build:bun": "bun --bun astro build --config astro.bun.ts --root __test__",
    "preview": "astro preview --config astro.default.ts --root __test__",
    "hooks:pre-commit": "lint-staged",
    "hooks:pre-push": "tsc --noEmit && vitest run",
    "hooks:commit-msg": "commitlint -e",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "piscina": "^5.2.0"
  },
  "devDependencies": {
    "@astrojs/node": "^10.1.4",
    "@astrojs/ts-plugin": "^1.10.9",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/lokijs": "^1.5.14",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "astro": "^6.4.8",
    "bun-types": "^1.3.14",
    "deterministic-object-hash": "^2.0.2",
    "kleur": "^4.1.5",
    "lefthook": "^2.1.9",
    "lokijs": "^1.5.12",
    "ora": "^9.4.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "sharp": "0.35.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "xxhash-addon": "^2.1.0"
  },
  "peerDependencies": {
    "astro": "^4.0.8 || ^5.0.0 || ^6.0.0",
    "deterministic-object-hash": "^2.0.1",
    "kleur": "^4.1.4",
    "lokijs": "^1.5.12",
    "ora": "^7.0.1 || ^8.0.1 || ^9.0.0",
    "sirv": "^3.0.2",
    "xxhash-addon": "^2.0.3"
  },
  "peerDependenciesMeta": {
    "lokijs": {
      "optional": true
    },
    "xxhash-addon": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">= 1",
    "node": ">= 22"
  },
  "volta": {
    "node": "24.17.0",
    "pnpm": "11.8.0"
  },
  "packageManager": "pnpm@11.8.0"
}
